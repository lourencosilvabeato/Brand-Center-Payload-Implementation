# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string. For local dev: postgres://postgres:<password>@127.0.0.1:5432/<db-name>
DATABASE_URL=postgres://postgres:your-db-password@127.0.0.1:5432/brand-center

# ─── Payload CMS ────────────────────────────────────────────────────────────
# Secret used to sign Payload JWT sessions. Use a long random string.
PAYLOAD_SECRET=your-long-random-secret-here

# ─── Azure AD (SSO for internal users) ──────────────────────────────────────
# Obtained from Azure Portal → App Registrations → your app
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-directory-tenant-id
# Must match a Redirect URI registered in the Azure app registration
AZURE_REDIRECT_URI=http://localhost:3000/api/users/oauth/callback/azure

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# SMTP credentials for sending transactional email (invites, password resets, contact)
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# Sender address shown in outgoing emails
EMAIL_FROM=noreply@example.com

# ─── Application ─────────────────────────────────────────────────────────────
# Public base URL — used to build absolute links in emails (invite, reset links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
